# MongoDB Atlas connection (Prisma)
DATABASE_URL="mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/khanfoods?retryWrites=true&w=majority&appName=Cluster0"

# Admin panel password (change in production!)
ADMIN_PASSWORD="your-secure-password"

# Public site URL for SEO (sitemap, OpenGraph)
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"

# Meta Pixel ID — exposed to browser for Pixel Helper + dedup with CAPI
NEXT_PUBLIC_META_PIXEL_ID="your-meta-pixel-id"

# ImgBB image hosting API key (https://api.imgbb.com)
IMGBB_API_KEY="your-imgbb-api-key"

# Meta Conversions API — server-side (never expose token to client)
META_PIXEL_ID="your-meta-dataset-or-pixel-id"
META_DATASET_ID="your-meta-dataset-id"
META_ACCESS_TOKEN="your-meta-conversions-api-access-token"
# Optional: Events Manager → Test Events → copy test code to see live server events
META_TEST_EVENT_CODE=""
